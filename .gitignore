# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/node_modules_old
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Prisma local database
prisma/dev.db
prisma/dev.db-journal
prisma/prisma/

# User uploads
/uploads/
/data/
/data-dev/

# local generated config/secrets
.blackvault.env
prisma/session-secret

# local Next.js backup artifacts
.next.bak.*/

# launcher/electron artifacts (kept ignored even though desktop is not V1 primary)
/launcher/node_modules/
/launcher/dist/
/electron/node_modules/
/electron/dist/
/electron/out/
/electron/release/

# local runtime data/signing artifacts
*.sqlite
*.sqlite-journal
*.db-wal
*.db-shm
*.bak
*.p12
*.pfx
*.cer
*.key
*.mobileprovision
.signing/
