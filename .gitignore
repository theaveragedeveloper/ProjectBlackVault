# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Prisma local database
prisma/dev.db
prisma/dev.db-journal
prisma/prisma/

# User uploads
/uploads/

# Electron launcher build artifacts
/launcher/node_modules/
/launcher/dist/

# Local app env/secrets
.blackvault.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Electron artifacts
/electron/node_modules/
/electron/dist/
/electron/out/
/electron/release/

# Local runtime data and backups
*.sqlite
*.sqlite-journal
*.db-wal
*.db-shm
*.bak
# Signing artifacts and certificate exports
*.p12
*.pfx
*.cer
*.key
*.mobileprovision
.signing/

