# ProjectBlackVault Docker settings
# Safe default: localhost-only. Set BIND_ADDRESS=0.0.0.0 only if you need phone/local-LAN access.
PORT=3000
BIND_ADDRESS=127.0.0.1
DATA_DIR=./data
IMAGE_UPLOAD_DIR=/app/uploads

# Optional: override the auto-generated session secret (minimum 32 chars).
# If empty, BlackVault will generate and persist a secure secret in /app/data/session-secret.
SESSION_SECRET=

# Cookie security mode: auto | true | false
# auto = secure cookies only when request is HTTPS / x-forwarded-proto=https
SESSION_COOKIE_SECURE=auto

# Optional: use a fixed app encryption key for at-rest encryption features
# If not set, encryption can still be configured from Settings in the UI.
VAULT_ENCRYPTION_KEY=

# Disabled by default: avoid exposing encryption key via API/UI backup flow
ALLOW_ENCRYPTION_KEY_EXPORT=false
