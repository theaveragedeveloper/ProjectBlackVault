# BlackVault configuration
# Copy this file to .env (or let install.sh generate it) and adjust as needed.

# Directory where BlackVault stores its database and uploaded images.
# Default is ./data (relative to the project folder).
# Use an absolute path (e.g. /home/yourname/.blackvault) if you prefer.
DATA_DIR=./data

# Port to expose BlackVault on.
PORT=3000
