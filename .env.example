# Required — SQLite database path
DATABASE_URL="file:./prisma/dev.db"

# Required — signs session cookies to prevent cookie forgery attacks
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional — override cookie `Secure` attribute.
# Defaults to true in production and false in local development.
# SESSION_COOKIE_SECURE=true

# Recommended in production — provides encryption key via environment
# (preferred over storing keys in the database).
# Generate with: openssl rand -hex 32
# VAULT_ENCRYPTION_KEY=

# Optional overrides for advanced/diagnostic scenarios (not recommended in production)
# ALLOW_DB_ENCRYPTION_KEY_MANAGEMENT=false
# ALLOW_ENCRYPTION_KEY_EXPORT=false
# EXPOSE_SYSTEM_INFO=false

# Optional — Google Custom Search integration for image search feature
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_SEARCH_ENGINE_ID=
