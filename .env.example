# Required — SQLite database path
DATABASE_URL="file:./prisma/dev.db"

# Required in production — signs session cookies to prevent forgery attacks
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Recommended for self-hosted Docker with reverse proxy
# Public HTTPS URL users should open/bookmark/install from
# Example: https://vault.yourdomain.com
APP_BASE_URL=

# Security-first defaults for internet egress (recommended for sensitive self-hosted data)
# Keep these unset/false to avoid outbound internet calls from app features.
# Set true only if you intentionally want these capabilities.
ALLOW_RELEASE_LOOKUP=false
ALLOW_IMAGE_SEARCH_EGRESS=false
ALLOW_EXTERNAL_IMAGE_URLS=false
# If enabling external image URLs in the browser UI, set this too at build time:
# NEXT_PUBLIC_ALLOW_EXTERNAL_IMAGE_URLS=true

# Restrict in-app update checks/execution to private LAN/VPN clients by default.
SYSTEM_UPDATE_REQUIRE_PRIVATE_NETWORK=true

# Optional — enables AES-256-GCM encryption at rest for serial numbers and notes
# Generate with: openssl rand -hex 32
# WARNING: Changing this key after data is stored makes existing encrypted data unrecoverable.
VAULT_ENCRYPTION_KEY=

# Optional but strongly recommended — dedicated secret for password/account recovery workflows
# Generate with: openssl rand -hex 32
# DO NOT reuse VAULT_ENCRYPTION_KEY here. Encryption and auth recovery must use different secrets.
# CRITICAL: If this value is exposed in screenshots, logs, chat paste, or tickets,
# an attacker may be able to take over accounts via recovery flows.
PASSWORD_RECOVERY_SECRET=

# Optional — Google Custom Search integration for image search feature
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_SEARCH_ENGINE_ID=
