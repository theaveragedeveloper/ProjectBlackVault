# BlackVault Configuration
# Copy this to .blackvault.env and fill in your values,
# or let install.sh generate it automatically.

# Port to expose BlackVault on (default: 3000)
PORT=3000

# Directory on your host where data is stored (default: ./data)
DATA_DIR=./data

# Encryption key — leave empty for V1 (encryption is disabled)
VAULT_ENCRYPTION_KEY=
