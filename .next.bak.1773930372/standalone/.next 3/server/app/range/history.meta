{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/range/layout,_N_T_/range/history/layout,_N_T_/range/history/page,_N_T_/range/history"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/range/history/__PAGE__",
    "/range/history",
    "/range",
    "/_index",
    "/_head"
  ]
}