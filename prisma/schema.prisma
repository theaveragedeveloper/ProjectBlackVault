generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── FIREARMS ─────────────────────────────────────────────────

model Firearm {
  id              String   @id @default(cuid())
  name            String
  manufacturer    String   @default("")
  model           String   @default("")
  caliber         String   @default("")
  serialNumber    String?  @unique
  // FirearmType: PISTOL | RIFLE | SHOTGUN | SMG | PCC | REVOLVER | BOLT_ACTION | LEVER_ACTION
  type            String   @default("")
  acquisitionDate DateTime?
  purchasePrice   Float?
  currentValue    Float?
  notes           String?
  imageUrl        String?
  // imageSource: "uploaded" | "google_cse" | "seed" | "url"
  imageSource     String?

  builds          Build[]
  rangeSessions   RangeSession[]
  maintenanceNotes MaintenanceNote[]
  maintenanceSchedules MaintenanceSchedule[]
  documents       Document[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([caliber])
  @@index([type])
}

// ─── BUILDS ───────────────────────────────────────────────────

model Build {
  id          String      @id @default(cuid())
  name        String
  description String?
  isActive    Boolean     @default(false)
  sortOrder   Int         @default(0)
  firearmId   String
  firearm     Firearm     @relation(fields: [firearmId], references: [id], onDelete: Cascade)

  slots       BuildSlot[]
  rangeSessions RangeSession[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([firearmId])
  @@index([isActive])
}

model BuildSlot {
  id          String     @id @default(cuid())
  buildId     String
  build       Build      @relation(fields: [buildId], references: [id], onDelete: Cascade)
  // SlotType: MUZZLE | BARREL | HANDGUARD | STOCK | BUFFER_TUBE | GRIP | OPTIC | OPTIC_MOUNT |
  //           UNDERBARREL | MAGAZINE | LIGHT | LASER | CHARGING_HANDLE | TRIGGER |
  //           LOWER_RECEIVER | UPPER_RECEIVER | SLIDE | FRAME | SUPPRESSOR | BIPOD | SLING |
  //           COMPENSATOR | MAGWELL
  slotType    String
  accessoryId String?
  accessory   Accessory? @relation(fields: [accessoryId], references: [id], onDelete: SetNull)

  // Position on the weapon canvas (percentage-based, 0-100)
  positionX   Float?
  positionY   Float?
  scaleX      Float?     @default(1.0)
  scaleY      Float?     @default(1.0)
  layerIndex  Int?       @default(0)

  @@unique([buildId, slotType])
  @@index([buildId])
  @@index([accessoryId])
}

// ─── ACCESSORIES ──────────────────────────────────────────────

model Accessory {
  id                     String          @id @default(cuid())
  name                   String
  manufacturer           String          @default("")
  model                  String?
  // type matches SlotType values above
  type                   String
  caliber                String?
  purchasePrice          Float?
  acquisitionDate        DateTime?
  notes                  String?
  imageUrl               String?
  imageSource            String?

  // Round count persists with the accessory across all builds
  roundCount             Int             @default(0)
  roundCountLogs         RoundCountLog[]

  buildSlots             BuildSlot[]
  documents              Document[]

  // Battery tracking
  hasBattery             Boolean         @default(false)
  batteryType            String?         // e.g. "CR2032", "AA"
  batteryChangedAt       DateTime?
  batteryIntervalDays    Int?            // how often to replace in days

  // Comma-separated compatible values, e.g. "RIFLE,SMG"
  compatibleFirearmTypes String?
  compatibleCalibers     String?

  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([type])
  @@index([roundCount])
}

model RoundCountLog {
  id            String    @id @default(cuid())
  accessoryId   String
  accessory     Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)
  roundsAdded   Int
  previousCount Int
  newCount      Int
  sessionNote   String?
  loggedAt      DateTime  @default(now())

  @@index([accessoryId])
  @@index([loggedAt])
}

// ─── RANGE SESSIONS ───────────────────────────────────────────

model RangeSession {
  id            String   @id @default(cuid())
  firearmId     String
  firearm       Firearm  @relation(fields: [firearmId], references: [id], onDelete: Cascade)
  buildId       String?
  build         Build?   @relation(fields: [buildId], references: [id], onDelete: SetNull)
  date          DateTime @default(now())
  roundsFired   Int
  rangeName     String?
  rangeLocation String?
  notes         String?

  // ── Environment / Weather ─────────────────────────────
  environment    String?   // "INDOOR" | "OUTDOOR"
  temperatureF   Float?    // degrees Fahrenheit
  windSpeedMph   Float?    // mph
  windDirection  String?   // e.g. "NW", "Headwind", "Crosswind"
  humidity       Float?    // 0-100 percentage
  lightCondition String?   // "BRIGHT" | "OVERCAST" | "LOW_LIGHT" | "NIGHT"
  weatherNotes   String?

  // ── Shot Group Data ───────────────────────────────────
  targetDistanceYd Float?  // yards
  groupSizeIn      Float?  // best group in inches
  groupSizeMoa     Float?  // MOA (best group)
  numberOfGroups   Int?
  groupNotes       String?

  // ── Relations ─────────────────────────────────────────
  sessionDrills  SessionDrill[]
  ammoLinks      SessionAmmoLink[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([firearmId])
  @@index([date])
}

model DrillTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  // category: "ACCURACY" | "SPEED" | "TACTICAL" | "FUNDAMENTALS" | "CUSTOM"
  category    String         @default("CUSTOM")
  // scoringType: "TIME" | "SCORE" | "TIME_AND_SCORE" | "PASS_FAIL" | "NOTES_ONLY"
  scoringType String         @default("NOTES_ONLY")
  parTime     Float?         // par time in seconds
  maxScore    Int?
  isBuiltIn   Boolean        @default(false)

  sessionDrills SessionDrill[]
  drillLogs     DrillLog[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([category])
}

model SessionDrill {
  id          String         @id @default(cuid())
  sessionId   String
  session     RangeSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  templateId  String?
  template    DrillTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  drillName   String         // denormalized; preserved if template is deleted
  timeSeconds Float?
  hits        Int?
  totalShots  Int?
  accuracy    Float?         // 0-100 percentage
  score       Float?
  notes       String?
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())

  @@index([sessionId])
  @@index([templateId])
}

model SessionAmmoLink {
  id            String          @id @default(cuid())
  sessionId     String
  session       RangeSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   AmmoTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, transactionId])
  @@index([sessionId])
  @@index([transactionId])
}

// ─── MAINTENANCE NOTES ────────────────────────────────────────

model MaintenanceNote {
  id          String   @id @default(cuid())
  firearmId   String
  firearm     Firearm  @relation(fields: [firearmId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  // type: "cleaning" | "repair" | "inspection" | "upgrade" | "other"
  type        String   @default("other")
  description String
  mileage     Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firearmId])
  @@index([date])
}

// ─── MAINTENANCE SCHEDULES ────────────────────────────────────

model MaintenanceSchedule {
  id              String                  @id @default(cuid())
  firearmId       String
  firearm         Firearm                 @relation(fields: [firearmId], references: [id], onDelete: Cascade)
  taskName        String
  // intervalType: "ROUNDS" | "DAYS"
  intervalType    String
  intervalValue   Int
  lastCompletedAt DateTime?
  lastRoundCount  Int?                    // firearm round count at last completion (for ROUNDS type)
  notes           String?
  completions     MaintenanceCompletion[]

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([firearmId])
}

model MaintenanceCompletion {
  id                     String              @id @default(cuid())
  scheduleId             String
  schedule               MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  completedAt            DateTime            @default(now())
  roundCountAtCompletion Int?
  notes                  String?

  createdAt              DateTime            @default(now())

  @@index([scheduleId])
}

// ─── AMMO ─────────────────────────────────────────────────────

model AmmoStock {
  id              String            @id @default(cuid())
  caliber         String
  brand           String
  grainWeight     Float?
  // bulletType: "FMJ" | "HP" | "OTM" | "Frangible" | "Tracer" | "Subsonic" | "Other"
  bulletType      String?
  quantity        Int               @default(0)
  purchasePrice   Float?
  purchaseDate    DateTime?
  storageLocation String?
  lowStockAlert   Int?
  notes           String?

  transactions    AmmoTransaction[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([caliber])
}

model AmmoTransaction {
  id           String   @id @default(cuid())
  stockId      String
  stock        AmmoStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  // type: PURCHASE | RANGE_USE | TRANSFER_OUT | INVENTORY_CORRECTION | EXPENDED
  type         String
  quantity     Int
  previousQty  Int
  newQty       Int
  note         String?
  transactedAt DateTime @default(now())

  sessionLinks SessionAmmoLink[]

  @@index([stockId])
  @@index([transactedAt])
}

// ─── IMAGE CACHE ──────────────────────────────────────────────

model ImageCache {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  searchQuery String
  imageUrl    String
  // source: "google_cse" | "uploaded" | "seed" | "url"
  source      String
  isApproved  Boolean  @default(false)
  width       Int?
  height      Int?
  cachedAt    DateTime @default(now())

  @@index([entityType, entityId])
}

// ─── DRILL LOGS ───────────────────────────────────────────────

model DrillLog {
  id          String         @id @default(cuid())
  templateId  String?
  template    DrillTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  drillName   String         // denormalized; preserved if template is deleted
  performedAt DateTime       @default(now())
  timeSeconds Float?
  hits        Int?
  totalShots  Int?
  accuracy    Float?         // 0-100 percentage
  score       Float?
  notes       String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([templateId])
  @@index([performedAt])
}

// ─── DOCUMENTS ────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  name        String
  // type: "RECEIPT" | "NFA_TAX_STAMP" | "OTHER"
  type        String   @default("RECEIPT")
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  notes       String?

  firearmId   String?
  firearm     Firearm?    @relation(fields: [firearmId], references: [id], onDelete: SetNull)
  accessoryId String?
  accessory   Accessory?  @relation(fields: [accessoryId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([firearmId])
  @@index([accessoryId])
  @@index([type])
}

// ─── SETTINGS ─────────────────────────────────────────────────

model AppSettings {
  id                      String   @id @default("singleton")
  googleCseApiKey         String?
  googleCseSearchEngineId String?
  enableImageSearch       Boolean  @default(false)
  defaultCurrency         String   @default("USD")
  appPassword             String?
  encryptionKey           String?
  dataStoragePath         String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
