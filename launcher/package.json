{
  "name": "projectblackvault-launcher",
  "version": "1.0.0",
  "description": "Desktop launcher for ProjectBlackVault — no terminal required",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "dist": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "io.github.theaveragedeveloper.projectblackvault",
    "productName": "ProjectBlackVault",
    "icon": "assets/icon.png",
    "extraResources": [
      { "from": "docker-compose.yml", "to": "docker-compose.yml" }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "artifactName": "${productName}-Setup.${ext}",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}.${ext}",
      "extendInfo": {
        "NSUIElement": 1
      }
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "theaveragedeveloper",
      "repo": "ProjectBlackVault"
    }
  }
}
